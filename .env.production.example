# Production Environment Variables for Netlify
# Copy this file to .env.production.local and fill in your values

# ============================================
# SUPABASE Configuration (REQUIRED)
# ============================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# PayPal Configuration (REQUIRED for subscriptions)
# ============================================
# Get your Client ID from PayPal Developer Dashboard
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id-here

# ============================================
# API Configuration (IMPORTANT - UPDATE THIS)
# ============================================
# Replace 'your-site-name' with your actual Netlify domain
# Format: https://your-site-name.netlify.app
NEXT_PUBLIC_API_URL=https://next-real-time-finance.netlify.app

# ============================================
# Portfolio Scraper Configuration (Optional)
# ============================================
# Required only if you enable the scraping feature
# Get cookies from investing.com by using browser DevTools
INVESTING_COOKIES=

# ============================================
# Environment
# ============================================
NODE_ENV=production

# ============================================
# Optional: Chrome/Chromium Path (for Puppeteer)
# ============================================
# Usually not needed, but can specify path if browser detection fails
# CHROME_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ============================================
# Optional: Database URL (if using external DB)
# ============================================
# Supabase handles this, so usually not needed
# DATABASE_URL=postgresql://user:password@host:port/database